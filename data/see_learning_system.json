,
  "assessment": {
    "welcome": "Let's create your perfect learning path. Answer 6 quick questions.",
    "sections": [
      {
        "title": "Language Skills",
        "questions": [
          {
            "id": "speaking_level",
            "question": "How comfortable are you speaking English with strangers? (1 = very nervous, 5 = confident)",
            "type": "scale",
            "min": 1,
            "max": 5
          },
          {
            "id": "listening_level", 
            "question": "How well do you understand spoken English in real conversations? (1 = struggle, 5 = excellent)",
            "type": "scale",
            "min": 1,
            "max": 5
          }
        ]
      },
      {
        "title": "Psychological State",
        "questions": [
          {
            "id": "anxiety",
            "question": "Social speaking anxiety level? (LearnMate style)",
            "type": "multiple",
            "options": ["High - avoid talking", "Medium - nervous but try", "Low - enjoy it"]
          },
          {
            "id": "motivation",
            "question": "What's driving you?",
            "type": "multiple",
            "options": ["Job/career", "Travel/social", "Personal growth", "Exam prep"]
          }
        ]
      },
      {
        "title": "Learning Preferences",
        "questions": [
          {
            "id": "format",
            "question": "Preferred practice style?",
            "type": "multiple",
            "options": ["Role-play scenarios", "VR immersion", "Chat with AI", "Audio exercises"]
          }
        ]
      }
    ],
    "profileMapping": {
      "high_anxiety_low_speaking_job": {
        "recommendedPath": "path-social-confidence",
        "startingDifficulty": "easy",
        "psySupport": "high"
      },
      "medium_anxiety_travel": {
        "recommendedPath": "path-travel-english",
        "startingDifficulty": "medium",
        "psySupport": "medium"
      }
    }
  }

